# Server
PORT=3333
NODE_ENV=development

# Database (must match docker-compose.yml credentials)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/futevolei_torneios?schema=public"

# JWT (single token, no refresh token for the MVP)
JWT_SECRET="change-me-jwt-secret"
JWT_EXPIRES_IN="7d"

# Resend (transactional email, used for password reset - RF03)
RESEND_API_KEY=""
EMAIL_FROM="Futevôlei Torneios <onboarding@resend.dev>"

# Mercado Pago (fill in when we reach the payments step)
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# Frontend URL (used in emails / CORS)
FRONTEND_URL="http://localhost:5173"
